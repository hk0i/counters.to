DOCKER_NETWORK_NAME=proxy_network

# Override to a LAN-reachable hostname (e.g. to.counters.lan, routed to this
# machine on your home network) to test on a real mobile device. Note: only
# *.localhost gets automatic secure-context treatment from browsers, which is
# what lets the service worker register over plain HTTP (see EDD section 8).
# A LAN hostname won't get that for free — PWA/offline behavior specifically
# won't be testable this way without real TLS, though the rest of the app
# works fine.
DEV_HOSTNAME=to.counters.localhost
